{
  "mcpServers": {
    "react-grab-mcp": {
      "command": "./packages/web/node_modules/.bin/react-grab",
      "args": ["mcp"]
    },
    "brave-devtools": {
      "command": "chrome-devtools-mcp",
      "args": [
        "--executablePath",
        "/usr/bin/brave-browser",
        "--isolated",
        "--viewport",
        "1920x1080",
        "--acceptInsecureCerts",
        "--no-usage-statistics",
        "--logFile",
        "/tmp/chrome-devtools-mcp--csf-live-json.log"
      ],
      "env": {
        "DEBUG": "",
        "CHROME_DEVTOOLS_MCP_NO_USAGE_STATISTICS": "1"
      }
    }
  }
}
